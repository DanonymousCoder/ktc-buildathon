{
  "manifest_version": 3,
  "name": "FlowSpace - PDF Reading Tracker",
  "version": "1.0.0",
  "description": "Automatically tracks your active PDF reading time across Chrome.",
  "permissions": [
    "storage",
    "tabs",
    "alarms",
    "idle"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
